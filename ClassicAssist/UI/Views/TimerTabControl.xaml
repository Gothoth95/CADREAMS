<UserControl x:Class="ClassicAssist.UI.Views.TimerTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:ClassicAssist.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewModels:TimerTabViewModel />
    </UserControl.DataContext>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Nuovo Timer" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Nome" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="1" Text="{Binding NewTimerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                <TextBlock Grid.Column="2" Text="Secondi" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="3" Text="{Binding NewTimerSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                <TextBlock Grid.Column="4" Text="X" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="5" Text="{Binding NewTimerX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                <TextBlock Grid.Column="6" Text="Y" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="7" Text="{Binding NewTimerY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                <Button Grid.Column="8" Content="Crea Timer" Command="{Binding AddTimerCommand}" MinWidth="90" />
            </Grid>
        </GroupBox>

        <ListView Grid.Row="1" ItemsSource="{Binding Timers}" SelectedItem="{Binding SelectedTimer}" Margin="0,0,0,8">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nome" Width="170" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Secondi" Width="70" DisplayMemberBinding="{Binding DurationSeconds}" />
                    <GridViewColumn Header="Rimanenti" Width="80" DisplayMemberBinding="{Binding RemainingSeconds}" />
                    <GridViewColumn Header="X" Width="60" DisplayMemberBinding="{Binding X}" />
                    <GridViewColumn Header="Y" Width="60" DisplayMemberBinding="{Binding Y}" />
                    <GridViewColumn Header="Stato" Width="80" DisplayMemberBinding="{Binding IsRunning}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Avvia" Command="{Binding StartTimerCommand}" Margin="0,0,8,0" MinWidth="80" />
            <Button Content="Ferma" Command="{Binding StopTimerCommand}" Margin="0,0,8,0" MinWidth="80" />
            <Button Content="Rimuovi" Command="{Binding RemoveTimerCommand}" MinWidth="80" />
        </StackPanel>
    </Grid>
</UserControl>
