<Window x:Class="ClassicAssist.UI.Views.Timers.TimerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="{DynamicResource ThemeWindowBackgroundBrush}"
        WindowStyle="ToolWindow"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="280"
        Height="66">
    <Border Background="#CC101010" BorderBrush="#FF4A4A4A" BorderThickness="1" CornerRadius="6" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="False" Grid.Row="0">
                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" />
                <TextBlock Text="{Binding RemainingSeconds, StringFormat={} {0}s}" Foreground="#FFCFCFCF" Margin="8,0,0,0" />
            </DockPanel>
            <ProgressBar Grid.Row="1"
                         Margin="0,8,0,0"
                         Height="18"
                         Minimum="0"
                         Maximum="{Binding DurationSeconds}"
                         Value="{Binding ElapsedSeconds}" />
        </Grid>
    </Border>
</Window>
