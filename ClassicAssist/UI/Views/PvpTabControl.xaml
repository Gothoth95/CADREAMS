<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
             xmlns:headered="clr-namespace:ClassicAssist.Controls.Headered;assembly=ClassicAssist.Controls"
             xmlns:controls="clr-namespace:ClassicAssist.Controls;assembly=ClassicAssist.Controls"
             xmlns:misc1="clr-namespace:ClassicAssist.UI.Misc"
             xmlns:data="clr-namespace:ClassicAssist.Data"
             xmlns:optionsTab="clr-namespace:ClassicAssist.UI.Views.OptionsTab"
             x:Class="ClassicAssist.UI.Views.PvpTabControl"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="920"
             Background="{DynamicResource ThemeInnerControlBackgroundBrush}">
    <d:DesignerProperties.DesignStyle>
        <Style TargetType="UserControl">
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}" />
        </Style>
    </d:DesignerProperties.DesignStyle>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PvpHeroTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor1Brush}" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PvpHeroKicker" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style x:Key="PvpHeroSubtitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor3Brush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="20" />
                <Setter Property="MaxWidth" Value="720" />
            </Style>

            <Style x:Key="PvpCard" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BackgroundColor2Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="Margin" Value="0,0,0,14" />
            </Style>
            <Style x:Key="SidebarItemText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor2Brush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <Style x:Key="SidebarNavButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor2Brush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{DynamicResource RadiusMd}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionColor1Brush}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionColor1EmphasizedBrush}" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundColor1Brush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PvpCardTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor1Brush}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
            <Style x:Key="PvpCardAccentRule" TargetType="Rectangle">
                <Setter Property="Fill" Value="{DynamicResource AccentColorBrush}" />
                <Setter Property="Height" Value="3" />
                <Setter Property="RadiusX" Value="1.5" />
                <Setter Property="RadiusY" Value="1.5" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Width" Value="40" />
                <Setter Property="Margin" Value="0,0,0,14" />
            </Style>

            <Style x:Key="PvpAccentActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="MinHeight" Value="38" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Background" Value="{DynamicResource AccentColorDimBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PvpInsetCode" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BackgroundColor1Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BackgroundColor5Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <Style x:Key="PvpNestedHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor2Brush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,12,0,8" />
            </Style>
            <Style x:Key="PvpNestedPanel" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BackgroundColor1Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>

            <Style TargetType="{x:Type headered:HorizontalHeaderedTextBox}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style TargetType="{x:Type headered:HorizontalHeaderedContentControl}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style TargetType="{x:Type headered:HorizontalHeaderedComboBox}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource WrapTextStyle}">
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#1A2243"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <Ellipse Width="48" Height="48" Fill="{DynamicResource AccentColorBrush}" />
                    <TextBlock Text="{x:Static resources:Strings.PvP}" Margin="0,10,0,2" Style="{StaticResource PvpCardTitle}" />
                    <TextBlock Text="{x:Static resources:Strings.PvP_tab_overview}" Foreground="{DynamicResource ForegroundColor3Brush}" FontSize="11" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,22,0,0">
                    <RadioButton x:Name="NavTarget"
                                 GroupName="PvpSections"
                                 IsChecked="True"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_target}" />
                    <RadioButton x:Name="NavColors"
                                 GroupName="PvpSections"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_colors}" />
                    <RadioButton x:Name="NavGuard"
                                 GroupName="PvpSections"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_guard}" />
                    <RadioButton x:Name="NavPvpCycle"
                                 GroupName="PvpSections"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_pvp_cycle}" />
                    <RadioButton x:Name="NavFriendly"
                                 GroupName="PvpSections"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_friendly}" />
                    <RadioButton x:Name="NavRehue"
                                 GroupName="PvpSections"
                                 Style="{StaticResource SidebarNavButton}"
                                 Content="{x:Static resources:Strings.PvP_section_rehue}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="{x:Static resources:Strings.PvP_tab_subtitle}"
                           Foreground="{DynamicResource ForegroundColor4Brush}"
                           FontSize="10.5"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource BackgroundColor1Brush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="14,12,14,0" Style="{StaticResource PvpCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.PvP}" Style="{StaticResource PvpHeroTitle}" />
                        <TextBlock Text="{x:Static resources:Strings.PvP_tab_subtitle}" Style="{StaticResource PvpHeroSubtitle}" Margin="0,6,0,0" />
                    </StackPanel>
                    <TextBox Grid.Column="1"
                             Height="34"
                             VerticalAlignment="Center"
                             Padding="10,0"
                             Text="{x:Static resources:Strings.PvP_section_placeholders}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14,10,14,14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavTarget, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_target}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <headered:HorizontalHeaderedComboBox Header="{x:Static resources:Strings.Smart_last_target_}" ItemsSource="{Binding Source={misc1:EnumBindingSource {x:Type data:SmartTargetOption}}}" SelectedItem="{Binding CurrentOptions.SmartTargetOption, Mode=TwoWay}" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Last_target_message_  }" Text="{Binding CurrentOptions.LastTargetMessage}" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Friend_target_message_}" Text="{Binding CurrentOptions.FriendTargetMessage}" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Friend_target_self_message_}" Text="{Binding CurrentOptions.FriendTargetSelfMessage}" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Enemy_target_message_}" Text="{Binding CurrentOptions.EnemyTargetMessage}" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Enemy_target_self_message_}" Text="{Binding CurrentOptions.EnemyTargetSelfMessage}" />
                            <controls:OptionedCheckBoxControl IsChecked="{Binding CurrentOptions.RangeCheckLastTarget}" Content="{x:Static resources:Strings.Range_check_last_target}">
                                <controls:OptionedCheckBoxControl.ChildContent>
                                    <TextBox Width="44" Margin="8,0,0,0" Text="{Binding CurrentOptions.RangeCheckLastTargetAmount}" />
                                </controls:OptionedCheckBoxControl.ChildContent>
                            </controls:OptionedCheckBoxControl>
                            <CheckBox IsChecked="{Binding CurrentOptions.PreventTargetingInnocentsInGuardzone}" Content="{x:Static resources:Strings.Prevent_targeting_innocents_in_guardzone}" />
                            <CheckBox IsChecked="{Binding CurrentOptions.PreventAttackingInnocentsInGuardzone}" Content="{x:Static resources:Strings.Prevent_attacking_innocents_in_guardzone}" />
                            <optionsTab:QueueLastTargetControl DataContext="{Binding}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavColors, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_colors}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <TextBlock Text="{x:Static resources:Strings.PvP_target_message_colors}" Foreground="{DynamicResource ForegroundColor3Brush}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Innocent"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyInnocent}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Innocent" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Ally"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyAlly}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Ally" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Gray / Attackable"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyAttackable}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Attackable" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Criminal"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyCriminal}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Criminal" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Enemy"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyEnemy}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Enemy" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Murderer"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyMurderer}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Murderer" /></Grid>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Invulnerable"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.HueNotorietyInvulnerable}" FontFamily="Consolas"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectNotorietyHueCommand}" CommandParameter="Invulnerable" /></Grid>
                            <Button Content="{x:Static resources:Strings.Test_notoriety_message_colors}" HorizontalAlignment="Left" Command="{Binding TestNotorietyHueCommand}" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavGuard, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_guard}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <TextBlock Text="{x:Static resources:Strings.Innocent_guard_zone_warning_hint}" TextWrapping="Wrap" Foreground="{DynamicResource ForegroundColor3Brush}" Margin="0,0,0,10" />
                            <headered:HorizontalHeaderedTextBox Header="{x:Static resources:Strings.Innocent_guard_zone_warning_message_}" Text="{Binding CurrentOptions.TargetNextInnocentGuardWarningMessage}" />
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{x:Static resources:Strings.Innocent_guard_zone_warning_hue_}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding CurrentOptions.TargetNextInnocentGuardWarningHue}" FontFamily="Consolas" Margin="8,0"/><Button Grid.Column="2" Content="Palette" Command="{Binding SelectInnocentGuardHueCommand}" /></Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavPvpCycle, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_pvp_cycle}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <Button Style="{StaticResource PvpAccentActionButton}" Content="{x:Static resources:Strings.Target_Next_PvP_Enemy}" Command="{Binding TargetNextPvpEnemyCommand}" />
                            <Border Style="{StaticResource PvpNestedPanel}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static resources:Strings.Target_Next_PvP_Notoriety}" Style="{StaticResource PvpNestedHeader}" Margin="0,0,0,6" />
                                    <CheckBox Content="Innocent" IsChecked="{Binding CurrentOptions.TargetNextPvpIncludeInnocent}" />
                                    <CheckBox Content="Gray / Attackable" IsChecked="{Binding CurrentOptions.TargetNextPvpIncludeGray}" />
                                    <CheckBox Content="Criminal" IsChecked="{Binding CurrentOptions.TargetNextPvpIncludeCriminal}" />
                                    <CheckBox Content="Enemy" IsChecked="{Binding CurrentOptions.TargetNextPvpIncludeEnemy}" />
                                    <CheckBox Content="Murderer" IsChecked="{Binding CurrentOptions.TargetNextPvpIncludeMurderer}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavFriendly, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_friendly}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <Button Style="{StaticResource PvpAccentActionButton}" Content="{x:Static resources:Strings.Target_Next_Friendly}" Command="{Binding TargetNextFriendlyCommand}" />
                            <Border Style="{StaticResource PvpNestedPanel}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static resources:Strings.Target_Next_Friendly_filters}" Style="{StaticResource PvpNestedHeader}" Margin="0,0,0,6" />
                                    <CheckBox Content="{x:Static resources:Strings.Target_Next_Friendly_include_ally}" IsChecked="{Binding CurrentOptions.TargetNextFriendlyIncludeAlly}" />
                                    <CheckBox Content="{x:Static resources:Strings.Target_Next_Friendly_include_friends}" IsChecked="{Binding CurrentOptions.TargetNextFriendlyIncludeFriends}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ElementName=NavRehue, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource PvpCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.PvP_section_rehue}" Style="{StaticResource PvpCardTitle}" />
                            <Rectangle Style="{StaticResource PvpCardAccentRule}" />
                            <TextBlock Text="{x:Static resources:Strings.Attack_Enemy___Rehue_Target}" Foreground="{DynamicResource ForegroundColor3Brush}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static resources:Strings.Attack_target_rehue_hue_}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding CurrentOptions.AttackTargetRehueHue}" FontFamily="Consolas" Margin="8,0" />
                                <Button Grid.Column="2" Content="Palette" Command="{Binding SelectAttackTargetHueCommand}" />
                            </Grid>
                            <Button Content="{x:Static resources:Strings.Test_attack_rehue_current_enemy_target}" Command="{Binding TestAttackTargetRehueCommand}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
